    "from scipy.stats import f_oneway\n",
    "\n",
    "\n",
    "print(\"TEST 5: ANOVA - BLOOD PRESSURE ACROSS AGE GROUPS\")\n",
    "\n",
    "\n",
    "# Create age groups\n",
    "df['Age_Group'] = pd.cut(df['Age'], bins=[0, 44, 54, 100], \n",
    "                         labels=['Young (29-44)', 'Middle (45-54)', 'Older (55+)'])\n",
    "\n",
    "# Split BP by age group\n",
    "young = df[df['Age_Group'] == 'Young (29-44)']['BP']\n",
    "middle = df[df['Age_Group'] == 'Middle (45-54)']['BP']\n",
    "older = df[df['Age_Group'] == 'Older (55+)']['BP']\n",
    "\n",
    "# Perform ANOVA\n",
    "f_statistic, p_value = f_oneway(young, middle, older)\n",
    "\n",
    "print(f\"\\nGroup Statistics:\")\n",
    "print(f\"  Young (29-44):  Mean={young.mean():.2f}, Std={young.std():.2f}, n={len(young):,}\")\n",
    "print(f\"  Middle (45-54): Mean={middle.mean():.2f}, Std={middle.std():.2f}, n={len(middle):,}\")\n",
    "print(f\"  Older (55+):    Mean={older.mean():.2f}, Std={older.std():.2f}, n={len(older):,}\")\n",
    "\n",
    "print(f\"\\nTest Results:\")\n",
    "print(f\"  F-statistic: {f_statistic:.4f}\")\n",
    "print(f\"  P-value: {p_value:.6f}\")\n",
    "\n",
    "if p_value < 0.05:\n",
    "    print(f\"\\n✓ SIGNIFICANT (p < 0.05)\")\n",
    "    print(f\"  Blood pressure DOES differ significantly across age groups.\")\n",
    "else:\n",
    "    print(f\"\\n✗ NOT SIGNIFICANT (p ≥ 0.05)\")\n",
    "\n",
